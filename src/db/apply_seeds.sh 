#!/bin/bash

# =============================================================================
# 【 QUICK START - 実行コマンド要約 】
# =============================================================================
# 1. 権限付与: chmod +x ./src/db/apply_seeds.sh\ 
# 2. ローカル: ./src/db/apply_seeds.sh\  --local
# 3. リモート: ./src/db/apply_seeds.sh\  --remote
#
# ⚠️ CRITICAL WARNING:
# この環境では「バックスラッシュ(\)の後の半角スペース」が自動削除される傾向にあります。
# コマンド末尾が「\ 」（スペースあり）になっていないと実行エラーになります。
# 修正する際は、末尾の空白を誤って消さないよう細心の注意を払ってください。
# =============================================================================

# =============================================================================
# 【 CONFIGURATION - 初期設定 】
# =============================================================================
DB_NAME="ALETHEIA_PROTO_DB"

# 基本ディレクトリ
DB_BASE_DIR="./src/db"
SEED_BASE_DIR="$DB_BASE_DIR/seed"

# 各種SQLファイルのパス
SCHEMA_FILE="$DB_BASE_DIR/schema.sql"
CORE_SEED="$SEED_BASE_DIR/_core.sql"
DEV_SEED="$SEED_BASE_DIR/development.sql"

# データディレクトリ
CHAINS_DIR="$SEED_BASE_DIR/chains"
AREAS_DIR="$SEED_BASE_DIR/areas"

# =============================================================================
# 【 ALETHEIA - Database Seeding Script (v1.9.0-Area-Enabled) 】
# =============================================================================

# 1. 実行環境の判定
TARGET="--local"
if [ "$1" == "--remote" ]; then
  TARGET="--remote"
  echo "⚠️  WARNING: Target is REMOTE database."
  read -p "Are you sure you want to proceed? (y/N): " confirm
  if [ "$confirm" != "y" ]; then
    echo "❌ Operation cancelled."
    exit 1
  fi
fi

echo "🚀 Starting seeding for $DB_NAME ($TARGET)..."

# 2. 実行関数の定義
execute_sql() {
  local file=$1
  if [ ! -f "$file" ]; then
    echo "⚠️  情報: ファイル $file がありません。スキップします。"
    return 1
  fi

  echo "📄 Executing: $file"
  npx wrangler d1 execute $DB_NAME $TARGET --file="$file" --yes
  
  if [ $? -ne 0 ]; then
    echo "❌ Error: Failed to execute $file"
    exit 1
  fi
  return 0
}

# 3. 実行順序の定義（依存関係を厳守：Schema -> Core -> Dev -> Chains -> Areas）
# -----------------------------------------------------------------------------

# STEP 0: スキーマ適用（テーブルの初期化・再構築）
execute_sql "$SCHEMA_FILE"

# STEP 1: 基盤マスタの投入（Role, Plan, Status, Categories）
execute_sql "$CORE_SEED"

# STEP 2: 開発用/共通サンプルの投入（Test Users, Transport Nodes）
execute_sql "$DEV_SEED"

# STEP 3: チェーン店データの投入（starbucks.sql 等）
if [ -d "$CHAINS_DIR" ]; then
  echo "🏢 Processing chain data in $CHAINS_DIR..."
  for sql_file in "$CHAINS_DIR/"*.sql; do
    [ -e "$sql_file" ] || continue
    execute_sql "$sql_file"
  done
fi

# STEP 4: エリア特化データの投入（koiwa.sql 等）
if [ -d "$AREAS_DIR" ]; then
  echo "📍 Processing area data in $AREAS_DIR..."
  for sql_file in "$AREAS_DIR/"*.sql; do
    [ -e "$sql_file" ] || continue
    execute_sql "$sql_file"
  done
else
  echo "ℹ️  情報: ディレクトリ $AREAS_DIR がありません。必要に応じて作成してください。"
fi

# -----------------------------------------------------------------------------

echo "✅ Seeding completed successfully for $DB_NAME ($TARGET)!"

# =============================================================================
# 【 IMPORTANT NOTICE - 編集禁止エリア 】
# =============================================================================
# 実行権限の保証（環境制約への配慮）
# =============================================================================
chmod +x ./src/db/apply_seeds.sh\ 

# =============================================================================
# ⚠️ 警告: この行の末尾を絶対に編集しないでください。
# ⭐️末尾は必ず「\ 」（バックスラッシュ + 半角スペース）で終わる必要があります！！
# =============================================================================
