#!/bin/bash

# =============================================================================
# 【 ALETHEIA - Database Seeding Script (v1.6.0-Zen-Refined) 】
# =============================================================================
# 使い方: 
#   [LOCAL]  
#     chmod +x ./src/db/apply_seeds.sh\  
#     ./src/db/apply_seeds.sh\   --local
#
#   [REMOTE] ※ 本番環境への反映
#     ./src/db/apply_seeds.sh\   --remote
#
# チェック方法：
#   npx wrangler d1 execute ALETHEIA_PROTO_DB --local --command="SELECT count(*) FROM services;"
# =============================================================================

# 1. 実行環境の判定
TARGET="--local"
if [ "$1" == "--remote" ]; then
  TARGET="--remote"
  echo "⚠️  WARNING: Target is REMOTE database."
  read -p "Are you sure you want to proceed? (y/N): " confirm
  if [ "$confirm" != "y" ]; then
    echo "❌ Operation cancelled."
    exit 1
  fi
fi

DB_NAME="ALETHEIA_PROTO_DB"

# 実際のディレクトリ構造 (ls -R の結果) に基づくパス設定
SEED_DIR="./src/db/seed"
# ls 結果から、development.sql の代わりに存在する seed.sql を指定
DEV_SEED="./src/db/seed.sql"

echo "🚀 Starting seeding for $DB_NAME ($TARGET)..."

# 2. 実行関数の定義
execute_sql() {
  local file=$1
  if [ ! -f "$file" ]; then
    echo "⚠️  Skip: $file not found."
    return
  fi

  echo "📄 Executing: $file"
  npx wrangler d1 execute $DB_NAME $TARGET --file="$file" --yes
  
  if [ $? -ne 0 ]; then
    echo "❌ Error: Failed to execute $file"
    exit 1
  fi
}

# 3. 実行順序の定義
# -----------------------------------------------------------------------------

# STEP 1: 基盤データ（プラン、カテゴリ、管理ユーザー等）
execute_sql "$SEED_DIR/_core.sql"

# STEP 2: チェーン店データの一括投入
echo "🏢 Processing chain data..."
if [ -d "$SEED_DIR/chains" ]; then
  for sql_file in "$SEED_DIR/chains/"*.sql; do
    [ -e "$sql_file" ] || continue
    execute_sql "$sql_file"
  done
else
  echo "⚠️  Skip: $SEED_DIR/chains directory not found."
fi

# STEP 3: 開発・検証用データ（ルートにある seed.sql）
execute_sql "$DEV_SEED"

# -----------------------------------------------------------------------------

echo "✅ Seeding completed successfully for $DB_NAME ($TARGET)!"

# 次回実行のための権限付与
chmod +x ./src/db/apply_seeds.sh\  