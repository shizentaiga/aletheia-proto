#!/bin/bash

# =============================================================================
# 【 CONFIGURATION - 初期設定（パス変更の際はこちらを修正） 】
# =============================================================================
DB_NAME="ALETHEIA_PROTO_DB"

# 基本ディレクトリ
DB_BASE_DIR="./src/db"
SEED_BASE_DIR="$DB_BASE_DIR/seed"

# 各種SQLファイルのパス
SCHEMA_FILE="$DB_BASE_DIR/schema.sql"
CORE_SEED="$SEED_BASE_DIR/_core.sql"
DEV_SEED="$SEED_BASE_DIR/development.sql"

# チェーン店データのディレクトリ（生成された starbucks.sql 等が格納される場所）
CHAINS_DIR="$SEED_BASE_DIR/chains"

# =============================================================================
# 【 ALETHEIA - Database Seeding Script (v1.7.0-Zen-Refined) 】
# =============================================================================
# 使い方: 
#   [LOCAL]  
#     chmod +x ./src/db/apply_seeds.sh\ 
#     ./src/db/apply_seeds.sh\  --local
#
#   [REMOTE] ※ 本番環境への反映
#     ./src/db/apply_seeds.sh\  --remote
#
# ※ 環境上の制約により、コマンド実行時は末尾に \ と 半角スペース が必要です。
# =============================================================================

# 1. 実行環境の判定
TARGET="--local"
if [ "$1" == "--remote" ]; then
  TARGET="--remote"
  echo "⚠️  WARNING: Target is REMOTE database."
  read -p "Are you sure you want to proceed? (y/N): " confirm
  if [ "$confirm" != "y" ]; then
    echo "❌ Operation cancelled."
    exit 1
  fi
fi

echo "🚀 Starting seeding for $DB_NAME ($TARGET)..."

# 2. 実行関数の定義
execute_sql() {
  local file=$1
  if [ ! -f "$file" ]; then
    echo "⚠️  エラー: ファイル $file がありません。スキップします。"
    return 1
  fi

  echo "📄 Executing: $file"
  # 環境制約に合わせてコマンド実行。--yesフラグで対話プロンプトをスキップ
  npx wrangler d1 execute $DB_NAME $TARGET --file="$file" --yes
  
  if [ $? -ne 0 ]; then
    echo "❌ Error: Failed to execute $file"
    exit 1
  fi
  return 0
}

# 3. 実行順序の定義（依存関係を厳守：Schema -> Core -> Development -> Chain）
# -----------------------------------------------------------------------------

# STEP 0: テーブルの初期化
execute_sql "$SCHEMA_FILE"

# STEP 1: 基盤データの投入（FOREIGN KEYの親側：Role, Plan, Categories等）
execute_sql "$CORE_SEED"

# STEP 2: 開発用/共通設定の投入（Sample Users, Transport Nodes等）
execute_sql "$DEV_SEED"

# STEP 3: チェーン店データの投入（ディレクトリ内の全SQLを順次実行）
# ※ starbucks.sql もこのディレクトリに含まれるため、一括して処理されます。
if [ -d "$CHAINS_DIR" ]; then
  echo "🏢 Processing chain data in $CHAINS_DIR..."
  for sql_file in "$CHAINS_DIR/"*.sql; do
    # ファイルが存在しない場合のガード
    [ -e "$sql_file" ] || continue
    execute_sql "$sql_file"
  done
else
  echo "ℹ️  情報: ディレクトリ $CHAINS_DIR がありません。スキップします。"
fi

# -----------------------------------------------------------------------------

echo "✅ Seeding completed successfully for $DB_NAME ($TARGET)!"

# 次回実行のための権限付与（環境制約に基づき \ と半角スペースを付与）
chmod +x ./src/db/apply_seeds.sh\ 