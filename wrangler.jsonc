{
  "name": "aletheia-app",
  "main": "src/index.tsx",
  "compatibility_date": "2024-04-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "aletheia-db",
      "database_id": "xxxx-xxxx-xxxx"
    }
  ]
}